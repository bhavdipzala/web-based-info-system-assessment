CREATE TABLE Users (
 Login VARCHAR(255) PRIMARY KEY,
 Password VARCHAR(255) NOT NULL,
 DisplayName VARCHAR(255) UNIQUE NOT NULL
);

CREATE TABLE Sequences (
 SequenceID INT AUTO_INCREMENT PRIMARY KEY,
 Name VARCHAR(255) NOT NULL,
 TotalLength INT NOT NULL,
 Login VARCHAR(255) NOT NULL,
 FOREIGN KEY (Login) REFERENCES Users(Login),
 CHECK (TotalLength > 0)
);

CREATE TABLE Tags(
 Name VARCHAR(255) PRIMARY KEY
);

CREATE TABLE SequenceTags(
 SequenceID INT NOT NULL,
 Name VARCHAR(255) NOT NULL,
 FOREIGN KEY (SequenceID) REFERENCES Sequences(SequenceID),
 FOREIGN KEY (Name) REFERENCES Tags(Name)
);

CREATE TABLE Poses (
 Name VARCHAR(255) PRIMARY KEY,
 Sides  INT, 
 Image VARCHAR(255) NOT NULL
);

CREATE TABLE SequencePoses(
 Duration TIME NOT NULL,
 Ordering INT,
 SequenceID INT NOT NULL AUTO_INCREMENT,
 Name VARCHAR(255) NOT NULL,
 CHECK (Duration > '00:00:00'),
 CHECK (ORDERING > 0),
 PRIMARY KEY (Ordering, SequenceID),
 FOREIGN KEY (SequenceID) REFERENCES Sequences(SequenceID),
 FOREIGN KEY (Name) REFERENCES Poses(Name)
);


